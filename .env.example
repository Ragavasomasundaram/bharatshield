# BharatShield — Environment Variables
# Copy this file to .env.local and fill in your keys
# All keys are optional — the app works without any of them

# ── AI Classification ──────────────────────────────────
# Claude API (for deep threat classification)
# Get free credits at: console.anthropic.com
VITE_CLAUDE_API_KEY=

# Groq API (free, fast — alternative to Claude)
# Get free key at: console.groq.com
VITE_GROQ_API_KEY=

# ── Indian Language APIs ───────────────────────────────
# Bhashini (Official Govt of India translation API)
# Register free at: bhashini.gov.in
VITE_BHASHINI_API_KEY=
VITE_BHASHINI_USER_ID=

# ── Data Sources ───────────────────────────────────────
# Shodan (OSINT — free tier available)
# Get key at: account.shodan.io
VITE_SHODAN_API_KEY=

# AbuseIPDB (threat intelligence — free tier)
# Get key at: abuseipdb.com
VITE_ABUSEIPDB_API_KEY=

# ── Security Monitoring ────────────────────────────────
# Wazuh (self-hosted — no key needed if running locally)
VITE_WAZUH_API_URL=http://localhost:55000
VITE_WAZUH_USERNAME=admin
VITE_WAZUH_PASSWORD=

# ── Deployment ─────────────────────────────────────────
# Set to 'true' for offline/air-gap mode (uses Ollama locally)
VITE_OFFLINE_MODE=false

# Ollama URL (for offline AI — install from ollama.ai)
VITE_OLLAMA_URL=http://localhost:11434
